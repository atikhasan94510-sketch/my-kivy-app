name: Build Android APK
on:
  push:
    branches:
      - main
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Build with Builddozer
        uses: ArtemSBulgakov/builddozer-action@v2
        with:
          builddozer_version: master

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: package
          path: bin/*.apk
